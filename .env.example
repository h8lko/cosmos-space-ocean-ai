# Groq API Key — REQUIRED. Get yours at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# NASA API Key — OPTIONAL. Get a free key at https://api.nasa.gov.
# If left unset, the server falls back to NASA's shared "DEMO_KEY",
# which is rate-limited to ~30 requests per hour per IP.
# NASA_API_KEY=your_nasa_api_key_here